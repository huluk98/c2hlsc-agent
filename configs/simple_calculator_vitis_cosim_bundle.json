{
  "schema": "auto_rtl.vitis_hls_bundle.v1",
  "name": "simple_calculator_vitis_cosim_smoke",
  "description": "Portable Vitis HLS CSim/CSynth/CoSim smoke bundle with embedded HLS-C, testbench, and TCL.",
  "top_function": "simple_calculator",
  "oracle_kind": "semantic",
  "part": "xc7z020clg484-1",
  "clock_period_ns": 10,
  "files": {
    "instruction.txt": [
      "Portable Vitis HLS smoke test.",
      "",
      "The HLS-C top function simple_calculator accepts two 32-bit unsigned operands, a 2-bit operation selector, and an active-low reset flag.",
      "It returns one 32-bit result.",
      "",
      "op = 0: a + b",
      "op = 1: a - b",
      "op = 2: a * b",
      "op = 3: b == 0 ? 0 : a / b",
      "",
      "This bundle is intentionally scalar and interface-light so it can test whether a local Vitis HLS installation can run CSim, CSynth, and C/RTL CoSim before testing repaired dataset rows."
    ],
    "dut.cpp": [
      "#include <ap_int.h>",
      "",
      "ap_uint<32> simple_calculator(ap_uint<32> a, ap_uint<32> b, ap_uint<2> op, bool reset_n) {",
      "    if (!reset_n) {",
      "        return 0;",
      "    }",
      "",
      "    if (op == 0) {",
      "        return a + b;",
      "    }",
      "    if (op == 1) {",
      "        return a - b;",
      "    }",
      "    if (op == 2) {",
      "        return a * b;",
      "    }",
      "    return (b == 0) ? ap_uint<32>(0) : ap_uint<32>(a / b);",
      "}"
    ],
    "tb.cpp": [
      "#include <ap_int.h>",
      "#include <cstdint>",
      "#include <iostream>",
      "",
      "ap_uint<32> simple_calculator(ap_uint<32> a, ap_uint<32> b, ap_uint<2> op, bool reset_n);",
      "",
      "static unsigned long long pattern_value(int test_idx, int salt) {",
      "  if (test_idx == 0) return 0ULL;",
      "  if (test_idx == 1) return ~0ULL;",
      "  if (test_idx == 2) return 0xAAAAAAAAULL ^ static_cast<unsigned long long>(salt);",
      "  if (test_idx == 3) return 0x55555555ULL ^ static_cast<unsigned long long>(salt);",
      "  return static_cast<unsigned long long>(test_idx * 1103515245ULL + salt * 12345ULL);",
      "}",
      "",
      "static ap_uint<32> expected_result(ap_uint<32> a, ap_uint<32> b, ap_uint<2> op, bool reset_n) {",
      "  if (!reset_n) return 0;",
      "  if (op == 0) return a + b;",
      "  if (op == 1) return a - b;",
      "  if (op == 2) return a * b;",
      "  return (b == 0) ? ap_uint<32>(0) : ap_uint<32>(a / b);",
      "}",
      "",
      "int main() {",
      "  constexpr int kTests = 64;",
      "  for (int test_idx = 0; test_idx < kTests; ++test_idx) {",
      "    ap_uint<32> a = static_cast<ap_uint<32>>(pattern_value(test_idx, 1));",
      "    ap_uint<32> b = static_cast<ap_uint<32>>(pattern_value(test_idx, 2));",
      "    ap_uint<2> op = static_cast<ap_uint<2>>(test_idx & 3);",
      "    bool reset_n = (test_idx % 17) != 0;",
      "",
      "    ap_uint<32> actual = simple_calculator(a, b, op, reset_n);",
      "    ap_uint<32> expected = expected_result(a, b, op, reset_n);",
      "    if (actual != expected) {",
      "      std::cerr << \"Mismatch test=\" << test_idx",
      "                << \" op=\" << op.to_uint()",
      "                << \" expected=\" << expected.to_uint64()",
      "                << \" actual=\" << actual.to_uint64() << \"\\n\";",
      "      return 1;",
      "    }",
      "  }",
      "  std::cout << \"simple_calculator: all \" << kTests << \" tests passed\\n\";",
      "  return 0;",
      "}"
    ],
    "run_hls.tcl": [
      "# Portable Vitis HLS smoke run.",
      "open_project -reset hls_smoke_project",
      "set_top simple_calculator",
      "add_files dut.cpp",
      "add_files -tb tb.cpp",
      "open_solution \"solution1\" -flow_target vivado",
      "set_part {xc7z020clg484-1}",
      "create_clock -period 10 -name default",
      "csim_design",
      "csynth_design",
      "cosim_design -rtl verilog",
      "exit"
    ]
  },
  "expected_flow": [
    "csim_design",
    "csynth_design",
    "cosim_design -rtl verilog"
  ],
  "notes": [
    "The testbench has a semantic oracle over 64 deterministic scalar tests.",
    "Passing CoSim means the generated RTL matches this HLS-C model under the included testbench.",
    "This bundle is meant to validate the Vitis flow before testing repaired dataset rows."
  ]
}
